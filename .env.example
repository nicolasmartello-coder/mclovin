# Slack — create app at https://api.slack.com/apps, install to workspace
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# GitHub — fine-grained PAT or classic: repo, pull_requests, contents
GITHUB_TOKEN=ghp_...

# Anthropic Claude (review + fix agent) — key from Console or your org’s Claude API access
ANTHROPIC_API_KEY=sk-ant-...
# Optional: must match a model your key can call (see README)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Default repo when /review or /fix omits owner/repo (optional)
DEFAULT_GITHUB_OWNER=
DEFAULT_GITHUB_REPO=

# Server (Fly/Railway set PORT)
PORT=3000

# Solo diagnóstico: true evita auth.test al arrancar (no arregla un token inválido)
# SLACK_SKIP_AUTH_TEST=true
